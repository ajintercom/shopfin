# Supabase – get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Intercom – App ID from Settings → Installation → Web
VITE_INTERCOM_APP_ID=your_app_id

# Intercom Identity Verification secret – Settings → Security → Identity Verification
# IMPORTANT: This secret must NEVER be used client-side in production.
# Use the included Supabase edge function (supabase/functions/intercom-hmac) instead.
# For local dev you can set it here; for production leave blank and use the edge function.
VITE_INTERCOM_SECRET=your_identity_verification_secret
